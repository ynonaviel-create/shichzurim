    {
      "id": "physics",
      "name": "פיסיקה לרפואנים ב׳",
      "code": "0-471-8-1021",
      "icon": "🔬",
      "blurb": "חשמל, מגנטיות ודימות רפואי",
      "order": 4,
      "year": 1,
      "semester": "ב",
      "status": "active",
      "accent": {
        "light": [
          "#2f7ed0",
          "#185FA5",
